{
  "name": "@amigo-ai/sdk",
  "version": "1.0.0-rc.2",
  "description": "Official TypeScript SDK for the classic Amigo API",
  "keywords": [
    "amigo",
    "sdk",
    "typescript",
    "api",
    "conversation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/types/index.d.ts",
  "files": [
    "assets",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "gen-types": "node scripts/gen.mjs",
    "openapi:sync": "node scripts/sync-openapi.mjs",
    "test": "vitest run --project unit",
    "test:dist": "vitest run --project dist",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --project unit",
    "build": "node scripts/gen.mjs && node scripts/build.mjs && tsc --project tsconfig.build.json",
    "dev": "node scripts/gen.mjs && node scripts/build.mjs --watch",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint 'src/**/*.{ts,tsx}' --max-warnings 0",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "pack:local": "npm run build && rm -rf artifacts && mkdir -p artifacts && TARBALL=$(npm pack) && mv \"$TARBALL\" artifacts/ && echo Packed: artifacts/$TARBALL",
    "prepare": "husky || true",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "lint-staged": {
    "src/**/*.{ts,js,mjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amigo-ai/amigo-typescript-sdk.git"
  },
  "author": "Amigo Inc.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/amigo-ai/amigo-typescript-sdk/issues"
  },
  "homepage": "https://github.com/amigo-ai/amigo-typescript-sdk",
  "devDependencies": {
    "@types/node": "^24.2.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.2.1",
    "esbuild": "^0.25.8",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.10.4",
    "openapi-typescript": "^7.8.0",
    "prettier": "^3.6.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "openapi-fetch": "^0.14.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0"
  }
}
